# Copy this file to .env in the project root and fill in your values.

# MongoDB connection for user accounts (signup/login). Local dev default
# below assumes `mongod` running on localhost with no auth. For deployment,
# use a MongoDB Atlas connection string instead, e.g.
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=techmart_support

# Hugging Face token (required). Create one at https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Any instruction-tuned chat model available via HF Inference Providers.
# Ungated models (no license click-through on huggingface.co) are the most
# reliable choice. Qwen2.5-7B-Instruct is a good free-tier default.
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
# "auto" = let HF pick the fastest provider serving this model. You can also
# pin one explicitly, e.g. "together", "groq", "fireworks-ai", "cerebras".
HF_PROVIDER=auto
HF_MAX_TOKENS=512
HF_TEMPERATURE=0.3

# Secret used to sign JWTs. Generate your own with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Do NOT reuse the placeholder below, and never commit your real .env.
JWT_SECRET=replace_with_your_own_random_64_char_hex_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Comma-separated emails allowed to view /api/analytics/summary (the admin
# dashboard, reachable at /analytics in the React app once logged in).
ADMIN_EMAILS=you@example.com

# Embedding model used for the RAG vector store.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=80
TOP_K=3

# Comma-separated list of allowed frontend origins, or "*" for all.
ALLOWED_ORIGINS=*
